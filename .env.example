# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://user:password@localhost:5432/veille_platform"
DATABASE_POOL_MIN="2"
DATABASE_POOL_MAX="10"

# ===========================================
# AUTHENTICATION
# ===========================================
AUTH_SECRET="your-super-secret-key-min-32-chars"
AUTH_SESSION_DURATION="7d"
AUTH_MAX_LOGIN_ATTEMPTS="5"
AUTH_LOCKOUT_DURATION="15m"

# ===========================================
# ADMIN
# ===========================================
ADMIN_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3000"

# ===========================================
# INTERNAL API
# ===========================================
API_URL="http://localhost:3001"
API_PORT="3001"
API_CORS_ORIGINS="http://localhost:3000,http://localhost:4321"

# ===========================================
# PUBLIC API
# ===========================================
PUBLIC_API_URL="http://localhost:3002"
PUBLIC_API_PORT="3002"
PUBLIC_API_RATE_LIMIT="100"

# ===========================================
# WORKER
# ===========================================
WORKER_ENABLED="true"
WORKER_CONCURRENCY="5"
WORKER_RETRY_ATTEMPTS="3"
WORKER_RETRY_DELAY="5s"

# ===========================================
# STORAGE
# ===========================================
STORAGE_BASE_PATH="./storage"
STORAGE_RAW_PATH="./storage/raw"
STORAGE_PROCESSED_PATH="./storage/processed"
STORAGE_EXPORTS_PATH="./storage/exports"
STORAGE_QUARANTINE_PATH="./storage/quarantine"
STORAGE_MAX_FILE_SIZE="10485760"

# ===========================================
# AI PROVIDERS
# ===========================================
AI_PROVIDER_DEFAULT="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4-turbo-preview"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-opus-20240229"

# ===========================================
# BILLING / STRIPE
# ===========================================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_FREE=""
STRIPE_PRICE_PREMIUM=""
STRIPE_PRICE_ASSOCIATION=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_TEAM=""

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW="60"
RATE_LIMIT_MAX="100"
RATE_LIMIT_API_KEY_MAX="1000"

# ===========================================
# SECURITY
# ===========================================
SECURITY_CSP_ENABLED="true"
SECURITY_HTTPS_ONLY="false"
SECURITY_TRUST_PROXY="true"
SECURITY_SSRF_ALLOWED_DOMAINS=""
SECURITY_MAX_UPLOAD_SIZE="10MB"
SECURITY_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/gif,image/webp,application/pdf"

# ===========================================
# MAIL
# ===========================================
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="veille@platform.io"

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL="info"
LOG_FORMAT="json"
LOG_AUDIT_ENABLED="true"

# ===========================================
# EXPORTS
# ===========================================
EXPORT_JSON_ENABLED="true"
EXPORT_MDX_ENABLED="true"
EXPORT_RSS_ENABLED="true"
EXPORT_ASTRO_SYNC_ENABLED="false"

# ===========================================
# SOURCE FETCHING
# ===========================================
FETCH_TIMEOUT_MS="30000"
FETCH_MAX_REDIRECTS="5"
FETCH_USER_AGENT="VeillePlatform/1.0 (+https://veille.platform)"
