{
  "name": "@database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/client.ts",
  "types": "./src/client.ts",
  "exports": {
    ".": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./utils": {
      "types": "./src/utils.ts",
      "import": "./src/utils.ts"
    }
  },
  "scripts": {
    "generate": "prisma generate --schema=./prisma/schema.prisma",
    "push": "prisma db push --schema=./prisma/schema.prisma",
    "migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=./prisma/schema.prisma --name init",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio --schema=./prisma/schema.prisma",
    "reset": "prisma migrate reset --schema=./prisma/schema.prisma --force",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.prisma\"",
    "clean": "rm -rf dist node_modules/.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.9.0"
  },
  "devDependencies": {
    "prisma": "^5.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
