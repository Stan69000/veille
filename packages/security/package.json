{
  "name": "@security",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./validators": {
      "types": "./src/validators/index.ts",
      "import": "./src/validators/index.ts"
    },
    "./guards": {
      "types": "./src/guards/index.ts",
      "import": "./src/guards/index.ts"
    },
    "./policies": {
      "types": "./src/policies/index.ts",
      "import": "./src/policies/index.ts"
    },
    "./ssrf": {
      "types": "./src/ssrf.ts",
      "import": "./src/ssrf.ts"
    },
    "./upload": {
      "types": "./src/upload.ts",
      "import": "./src/upload.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@core": "workspace:*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
