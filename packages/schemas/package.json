{
  "name": "@schemas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts"
    },
    "./items": {
      "types": "./src/items/index.ts",
      "import": "./src/items/index.ts"
    },
    "./stories": {
      "types": "./src/stories/index.ts",
      "import": "./src/stories/index.ts"
    },
    "./sources": {
      "types": "./src/sources/index.ts",
      "import": "./src/sources/index.ts"
    },
    "./users": {
      "types": "./src/users/index.ts",
      "import": "./src/users/index.ts"
    },
    "./common": {
      "types": "./src/common/index.ts",
      "import": "./src/common/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@core": "workspace:*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
